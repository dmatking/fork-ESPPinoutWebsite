{
  "id": "esp32devkitc",
  "name": "ESP32-DevKitC",
  "baseChip": "esp32",
  "pcb": "black",
  "notes": [
    "Espressif's official ESP32-DevKitC (ESP32-WROOM-32), 38 pins with one 19-pin header row per side. Electrically identical to the Elegoo ESP32 and the NodeMCU-32S clones.",
    "GPIO6-11 (CLK / SD0 / SD1 / SD2 / SD3 / CMD) are broken out on the header but wired to the internal SPI flash. Using them crashes the chip."
  ],
  "headers": {
    "leftRailHoles": 19,
    "rightRailHoles": 19,
    "left": [
      { "label": "3V3" },
      { "label": "EN" },
      { "gpio": 36 },
      { "gpio": 39 },
      { "gpio": 34 },
      { "gpio": 35 },
      { "gpio": 32 },
      { "gpio": 33 },
      { "gpio": 25 },
      { "gpio": 26 },
      { "gpio": 27 },
      { "gpio": 14 },
      { "gpio": 12 },
      { "label": "GND" },
      { "gpio": 13 },
      { "gpio": 9 },
      { "gpio": 10 },
      { "gpio": 11 },
      { "label": "5V" }
    ],
    "right": [
      { "label": "GND" },
      { "gpio": 23 },
      { "gpio": 22 },
      { "gpio": 1 },
      { "gpio": 3 },
      { "gpio": 21 },
      { "label": "GND" },
      { "gpio": 19 },
      { "gpio": 18 },
      { "gpio": 5 },
      { "gpio": 17 },
      { "gpio": 16 },
      { "gpio": 4 },
      { "gpio": 0 },
      { "gpio": 2 },
      { "gpio": 15 },
      { "gpio": 8 },
      { "gpio": 7 },
      { "gpio": 6 }
    ]
  },
  "overrides": {
    "36": { "label": "VP" },
    "39": { "label": "VN" },
    "1": { "label": "TX0" },
    "3": { "label": "RX0" },
    "17": { "label": "TX2" },
    "16": { "label": "RX2" },
    "9": { "label": "SD2" },
    "10": { "label": "SD3" },
    "11": { "label": "CMD" },
    "8": { "label": "SD1" },
    "7": { "label": "SD0" },
    "6": { "label": "CLK" }
  },
  "usbEdge": "bottom",
  "aspect": 0.589
}
